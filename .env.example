APP_NAME="One Stop Food"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production: use MySQL/MariaDB
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=food_order_delivery
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Behind nginx, Apache, or ngrok — comma-separated IPs or * for all
TRUSTED_PROXIES=*

# Dar es Salaam hub for distance-based delivery fees
DELIVERY_HUB_LAT=-6.7924
DELIVERY_HUB_LNG=39.2083

# Development only: auto-mark mobile/card payments as paid (never enable in production)
AUTO_CONFIRM_PAYMENTS=false

# M-Pesa Daraja / Vodacom (set MPESA_ENABLED=true when credentials are ready)
MPESA_ENABLED=false
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public HTTPS URL, e.g. https://your-domain.com/payments/mpesa/callback
MPESA_CALLBACK_URL=
# Tanzania Vodacom sandbox example:
# MPESA_BASE_URL=https://openapi.m-pesa.com/sandbox/ipg/v2/vodacomTZN
# Kenya Safaricom sandbox (default if MPESA_BASE_URL empty):
# sandbox: https://sandbox.safaricom.co.ke | production: https://api.safaricom.co.ke
MPESA_BASE_URL=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Tigo Pesa (Mix by Yas) — set TIGO_ENABLED=true when ready
TIGO_ENABLED=false
TIGO_ENV=sandbox
TIGO_CLIENT_ID=
TIGO_CLIENT_SECRET=
TIGO_MERCHANT_ID=
TIGO_ACCOUNT_MSISDN=
TIGO_CALLBACK_URL=
# TIGO_BASE_URL=https://api.tigo.co.tz/sandbox

# Airtel Money — set AIRTEL_ENABLED=true when ready
AIRTEL_ENABLED=false
AIRTEL_ENV=sandbox
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_COUNTRY=TZ
AIRTEL_CURRENCY=TZS
AIRTEL_CALLBACK_URL=
# Sandbox: https://openapiuat.airtel.africa | Production: https://openapi.airtel.africa
